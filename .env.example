# ═══════════════════════════════════════════════════════════════════════════════
#  PepperImports — Exemplo de Variáveis de Ambiente
#  Copie este arquivo para .env (dev) ou .env.production (prod)
#  e preencha os valores reais.
#  ⚠️  NUNCA commitar .env ou .env.production com valores reais!
# ═══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=PepperImports
POSTGRES_USER=postgres
POSTGRES_PASSWORD=COLOQUE_SENHA_FORTE_AQUI

# ── JWT ────────────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 64
# Mínimo 32 caracteres para HS256
JWT_SECRET=GERE_UM_SECRET_FORTE_AQUI_MIN_32_CHARS

# ── Frontend ───────────────────────────────────────────────────────────────────
# DEV local:  http://localhost:5139
# PROD VPS:   https://seudominio.com
VITE_API_URL=http://localhost:5139

# ── Portas expostas no host ────────────────────────────────────────────────────
FRONTEND_PORT=5173
BACKEND_PORT=5139
POSTGRES_PORT=5432
NGINX_PORT=80
